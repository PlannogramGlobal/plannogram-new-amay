# Copy these lines into .env.local (do not commit .env.local).
# Generate INITIATIVES_ADMIN_SECRET with: openssl rand -hex 32
#
# Same variables sign you into:
#   /site/admin/initiatives
#   /site/admin/blogs
#
# Vercel Blob (optional): add in Vercel → Storage → Blob → connect to project.
# When set, uploads and initiatives/blogs JSON sync for all users and deploys.
# Local dev: pull env with `vercel env pull` or paste token from Blob dashboard.
# BLOB_READ_WRITE_TOKEN=

INITIATIVES_ADMIN_USER=nhlkdr
INITIATIVES_ADMIN_PASSWORD=
INITIATIVES_ADMIN_SECRET=
